# NOTE:
# - CLI tools (autoprove.py / interactive_prove.py) use environment variables.
# - Web UI (web_prover.py) now expects keys entered in the browser and approved.

AXLE_API_KEY=your_axle_api_key_here

# OpenRouter (recommended for this setup)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4.1-mini
# Optional but recommended for OpenRouter usage tracking
# OPENROUTER_HTTP_REFERER=https://your-app.example
# OPENROUTER_APP_NAME=axle-lean-autoprove

# Optional: direct OpenAI provider
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
